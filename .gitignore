# Visual Studio 2015 user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/*
Plugins/**/Binaries/*

# Builds
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

Content/__ExternalActors__/*
Content/Audio/*
Content/BookHeadMonster/*
Content/Collections/*
Content/Developers/*
Content/Effects/*
Content/Enemy_Assets/*
Content/Environment/*
Content/Fantasy_Pack/*
Content/FPS_Assault_Pack/*
Content/FPS_Automatic_Rifle_02/*
Content/FPS_Automatic_Shotgun/*
Content/FPS_Pistol_Knife/*
Content/FPS_Pistol_Shield/*
Content/FPS_Pistol_Single/*
Content/FPS_Rocket_Launcher/*
Content/FPS_Sniper_Rifle_03/*
Content/FPS_Starter_Pack/*
Content/FPS_Weapon_Bundle/*
Content/FPSAssets/*
Content/Materials/*
Content/Megascans/*
Content/Meshes/*
Content/MilitaryWeapDark/*
Content/MSPresets/*
Content/PhysMat/*
Content/Primitive_Characters_Pack/*
Content/Textures/*
Content/ThirdParty/*

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/**/Intermediate/*

# Cache files for the editor to use
DerivedDataCache/*
